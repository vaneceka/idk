<!DOCTYPE html>
<html lang="cs">
    <head>
        <title>{% block title %}{% endblock %}Generátor zadání</title>

        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <link rel="stylesheet" href="/{{ basePath }}css/bootstrap.min.css">
        <script src="/{{ basePath }}js/bootstrap.bundle.min.js"></script>
        <script src="/{{ basePath }}js/site.js"></script>
    </head>
    <body class="bg-secondary-subtle">
        <header>
            <nav class="navbar navbar-dark bg-dark navbar-expand-xl">
                <div class="container-fluid">
                    <a class="navbar-brand" title="Generátor zadání" href="{% if loggedUser %}{{ createLink('admin') }}{% else %}/{% endif %}">Generátor zadání</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mb-2 mb-xl-0">
                            {% if loggedUser %}
                                <li class="nav-item">
                                    <a class="nav-link {{ isLinkCurrent('admin') ? 'active" aria-current="page' }}" href="{{ createLink('admin') }}">Vaše předměty</a>
                                </li>
                                {% if loggedUser.isAdmin %}
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Administrace
                                        </a>
                                        <ul class="dropdown-menu">
                                            <li>
                                                <a class="dropdown-item {{ isLinkCurrent('admin/profiles') ? 'active" aria-current="page' }}" href="{{ createLink('admin/profiles') }}">Profily zadání</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item {{ isLinkCurrent('admin/subjects') ? 'active" aria-current="page' }}" href="{{ createLink('admin/subjects') }}">Předměty</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item {{ isLinkCurrent('admin/users') ? 'active" aria-current="page' }}" href="{{ createLink('admin/users') }}">Vyučující</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item {{ isLinkCurrent('admin/options') ? 'active" aria-current="page' }}" href="{{ createLink('admin/options') }}">Nastavení</a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item {{ isLinkCurrent('admin/log') ? 'active" aria-current="page' }}" href="{{ createLink('admin/log') }}">Záznam aktivit</a>
                                            </li>
                                        </ul>
                                    </li>
                                {% endif %}
                                <li class="nav-item">
                                    <span class="nav-link">{{ loggedUser.name ~ ' ' ~ loggedUser.surname }}</span>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ createLink('admin/logout') }}">Odhlásit se</a>
                                </li>
                            {% elseif loggedStudent %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ createLink('assignments') }}">Domů</a>
                                </li>
                                <li class="nav-item">
                                    <span class="nav-link">{{ loggedStudent.name ~ ' ' ~ loggedStudent.surname }}</span>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ createLink('logout') }}">Odhlásit se</a>
                                </li>
                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link {{ isLinkCurrent('admin') ? 'active" aria-current="page' }}" href="{{ createLink('admin') }}">Administrace</a>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        {% block preContent %}
        {% for alert in alertMessages %}
            <div class="alert alert-{{ alert.class }}">
                {{ alert.message }}
            </div>
        {% endfor %}
        {% endblock %}
        <main class="container-fluid mt-3">
            <div class="bg-white p-3 rounded-3">
                {% block content %}
                {% endblock %}
            </div>
            <footer class="text-center mt-5 mb-2 text-secondary">
                &copy; Michal Turek 2025
            </footer>
        </main>
    </body>
</html>