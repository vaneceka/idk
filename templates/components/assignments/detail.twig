<h1>Zadání {{ assignment.name }}</h1>
<div>
    Datum zveřejnění: <b>{{ assignment.dateFrom|date("j. n. Y H:i") }}</b>
</div>
<div>
    Mezní termín odevzdání: <b>{{ assignment.dateTo|date("j. n. Y H:i") }}</b>
</div>
<div class="row">
    <div class="col-lg-8 order-1 order-md-0">
        <div class="border p-1">
            <pre style="white-space: pre-wrap">{{ assignmentText }}</pre>
        </div>
    </div>
    <div class="col-lg-4 order-0 order-md-1">
        <div class="table-responsive mt-2">
            <table class="table table-bordered">
                <thead>
                <tr>
                    <th>Název</th>
                    <th>Typ</th>
                    <th>Akce</th>
                </tr>
                </thead>
                <tbody>
                {% for file in files %}
                    <tr>
                        <td>{{ file.filename }}</td>
                        <td>{{ file.filetype.getName() }}</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="{{ createLink('assignments', { id: assignment.id, file: file.id }) }}">Stáhnout</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="border p-3">
            <h2>Odevzdání</h2>
            {% if attempts > 0 and details.state is constant('\\App\\Model\\Database\\Types\\AssignmentState::NEW') %}
                <div class="fs-5 alert alert-info">
                    Práce již byla odevzdána.
                    <br>Počet pokusů: {{ attempts }}
                </div>
            {% endif %}
            {% if details.state is constant('\\App\\Model\\Database\\Types\\AssignmentState::REJECTED') %}
                <div class="fs-5 alert alert-danger">
                    Práce byla zamítnuta.
                </div>
            {% elseif details.state is constant('\\App\\Model\\Database\\Types\\AssignmentState::ACCEPTED') %}
                <div class="fs-5 alert alert-success">
                    Práce byla přijata.
                </div>
            {% elseif assignment.dateTo > now %}
                {% if details.state is constant('\\App\\Model\\Database\\Types\\AssignmentState::RETURNED') %}
                    <div class="fs-5 alert alert-warning">
                        Práce byla vrácena k přepracování.
                    </div>
                {% endif %}
                <form method="post" action="{{ currentUrl }}" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="attachment">Vypracování</label>
                        <input type="file" name="attachment" id="attachment" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <input type="submit" name="submit_attachment_form" class="btn btn-success" value="Odevzdat">
                        {% if canShowValidatorReport %}
                            <div class="mt-3">
                                <button
                                    class="btn btn-outline-secondary" type="button" onclick="toggleValidatorReport()"id="validatorReportToggleBtn">
                                    {% if showValidatorReportSection %}
                                        Skrýt automatickou kontrolu validátorem
                                    {% else %}
                                        Zobrazit automatickou kontrolu validátorem
                                    {% endif %}
                                </button>
                            </div>
                        {% endif %}

                        {% if canShowValidatorReport %}
                            <div id="validatorReportWrapper" class="mt-4" style="{% if not showValidatorReportSection %}display:none;{% endif %}">
                                <hr class="mt-4">

                                <h2>Automatická kontrola</h2>

                                {% if checkerReport %}
                                    <div class="mb-3">
                                        <strong>Penalizace:</strong> {{ checkerReport.total_penalty }}
                                    </div>

                                    {% set failedAll = checkerReport.entries |filter(e => e.passed == false and (e.points|abs) >= studentViewMinPenalty) | sort((a, b) => a.points <=> b.points) %}

                                    {% if failedAll|length == 0 %}
                                        <div class="alert alert-success">Všechny kontroly prošly.</div>
                                    {% else %}
                                        <div class="border rounded p-2 bg-light" style="height: 350px; overflow: auto; resize: vertical; min-height: 180px;">
                                            {% for e in failedAll %}
                                                <div class="bg-white border rounded p-2 mb-2">
                                                    <div class="fw-semibold">{{ e.code }} — {{ e.name }}</div>
                                                    <div class="text-muted small">{{ e.category }}</div>
                                                    <div class="small">Body: {{ e.points }}</div>

                                                    {% if e.message %}
                                                        <div class="mt-2 small" style="white-space: pre-line; word-break: break-word;">
                                                            {{ e.message|trim }}
                                                        </div>
                                                    {% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                {% else %}
                                    <div class="alert alert-warning">
                                        Výsledek automatické kontroly zatím není dostupný.
                                    </div>
                                {% endif %}
                            </div>

                            <script>
                                function toggleValidatorReport() {
                                    const wrapper = document.getElementById('validatorReportWrapper');
                                    const btn = document.getElementById('validatorReportToggleBtn');

                                    if (!wrapper || !btn) return;

                                    const isHidden = wrapper.style.display === 'none' || wrapper.style.display === '';

                                    if (isHidden) {
                                        wrapper.style.display = 'block';
                                        btn.textContent = 'Skrýt automatickou kontrolu validátorem';
                                    } else {
                                        wrapper.style.display = 'none';
                                        btn.textContent = 'Zobrazit automatickou kontrolu validátorem';
                                    }
                                }
                            </script>
                        {% endif %}
                    </div>
                </form>
            {% else %}
                <p class="text-danger">
                    Práci již nelze znovu odevzdat.
                </p>
            {% endif %}
            {% if details.result %}
                <div><b>Komentář vyučujícího</b></div>
                {{ details.result|nl2br }}
            {% endif %}
        </div>
    </div>
</div>