<h1>Konfigurace kontrol</h1>

<form method="post" action="{{ createLink('admin/students', { action:'checks-config', event:event.id }) }}" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="file">Nahrát konfiguraci (.json)</label>
        <input id="file" class="form-control" type="file" name="file" required accept=".json,application/json">
        <div class="form-text">Nahrajte JSON konfiguraci kontrol pro tento předmět/akci.</div>
    </div>

    <div class="mb-3">
        <input type="submit" class="btn btn-outline-success" name="admin_checks_config_upload" value="Nahrát konfiguraci">
    </div>
</form>

<hr>

<h2>Ruční výběr kontrol</h2>

<form method="post" action="{{ createLink('admin/students', { action:'checks-config', event:event.id }) }}">
    <div class="row">
        <div class="col-md-6">
            <h3>Text (Word/Writer)</h3>
            <div class="border rounded p-2" style="max-height: 420px; overflow:auto;">
                {% for c in textChecks %}
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                            id="t_{{ c.code }}"
                            name="text[{{ c.code }}]"
                            value="1"
                            {% if c.enabled %}checked{% endif %}>
                        <label class="form-check-label" for="t_{{ c.code }}">
                            <strong>{{ c.code }}</strong>{% if c.title is defined %} — {{ c.title }}{% endif %}
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="col-md-6">
            <h3>Spreadsheet (Excel/Calc)</h3>
            <div class="border rounded p-2" style="max-height: 420px; overflow:auto;">
                {% for c in sheetChecks %}
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                            id="s_{{ c.code }}"
                            name="spreadsheet[{{ c.code }}]"
                            value="1"
                            {% if c.enabled %}checked{% endif %}>
                        <label class="form-check-label" for="s_{{ c.code }}">
                            <strong>{{ c.code }}</strong>{% if c.title is defined %} — {{ c.title }}{% endif %}
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-outline-primary" name="admin_checks_config_save">
            Uložit výběr
        </button>

        <button type="submit" class="btn btn-outline-secondary" name="admin_checks_config_reset"
                onclick="return confirm('Opravdu chcete obnovit výchozí konfiguraci?')">
            Obnovit výchozí
        </button>
    </div>
</form>