<h1>Vaše předměty ({{ currentSemester.getName() }} semestr {{ currentYear }}/{{ currentYear + 1 }})</h1>
<div class="table-responsive mt-2">
    <table class="table table-bordered">
        <thead>
        <tr>
            <th>Zkratka</th>
            <th>Předmět</th>
            <th>Akce</th>
        </tr>
        </thead>
        <tbody>
        {% for subject in subjects %}
            <tr>
                <td>{{ subject.shortcut }}</td>
                <td>{{ subject.name }}</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" href="{{ createLink('admin', { subject: subject.id }) }}">Otevřít</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>